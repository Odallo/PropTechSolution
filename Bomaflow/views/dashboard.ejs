<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BomaFlow - Landlord Dashboard</title>
    
    <!-- Google Fonts: Fraunces (serif) and Nunito (rounded sans-serif) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@600;700;800&family=Nunito:wght@400;600;700&display=swap" rel="stylesheet">
    
    <style>
        /* Design Token System - Organic/Natural Theme */
        :root {
            /* Colors - Forest floor, clay, unbleached paper palette */
            --background: #FDFCF8;
            --foreground: #2C2C24;
            --primary: #5D7052;
            --primary-foreground: #F3F4F1;
            --secondary: #C18C5D;
            --secondary-foreground: #FFFFFF;
            --accent: #E6DCCD;
            --accent-foreground: #4A4A40;
            --muted: #F0EBE5;
            --muted-foreground: #78786C;
            --border: #DED8CF;
            --destructive: #A85448;
            
            /* Typography */
            --font-heading: 'Fraunces', serif;
            --font-body: 'Nunito', sans-serif;
            
            /* Shadows - Soft, colored, never pure black */
            --shadow-soft: 0 4px 20px -2px rgba(93, 112, 82, 0.15);
            --shadow-float: 0 10px 40px -10px rgba(193, 140, 93, 0.2);
            --shadow-hover: 0 6px 24px -4px rgba(93, 112, 82, 0.25);
            
            /* Organic border radii */
            --radius-sm: 1rem;
            --radius-md: 1.5rem;
            --radius-lg: 2rem;
            --radius-xl: 3rem;
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: var(--font-body);
            background: var(--background);
            color: var(--foreground);
            padding: 20px;
            position: relative;
            overflow-x: hidden;
        }
        
        /* Global texture overlay - paper grain effect */
        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: 
                url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' opacity='0.04'/%3E%3C/svg%3E");
            mix-blend-mode: multiply;
            pointer-events: none;
            z-index: 1;
        }
        
        .container {
            max-width: 1200px;
            margin: 0 auto;
            position: relative;
            z-index: 2;
        }
        
        /* Header with organic blob shapes */
        .header {
            position: relative;
            background: var(--primary);
            color: var(--primary-foreground);
            padding: 40px;
            border-radius: var(--radius-xl);
            margin-bottom: 40px;
            overflow: hidden;
            box-shadow: var(--shadow-float);
        }
        
        /* Organic blob backgrounds */
        .header::before,
        .header::after {
            content: '';
            position: absolute;
            border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%;
            filter: blur(3rem);
            opacity: 0.3;
        }
        
        .header::before {
            top: -20%;
            right: -10%;
            width: 40%;
            height: 60%;
            background: var(--secondary);
        }
        
        .header::after {
            bottom: -15%;
            left: -5%;
            width: 35%;
            height: 50%;
            background: var(--accent);
        }
        
        .header h1 {
            font-family: var(--font-heading);
            font-size: 2rem;
            font-weight: 800;
            margin-bottom: 12px;
            position: relative;
            z-index: 2;
        }
        
        .header p {
            opacity: 0.9;
            font-size: 1.1rem;
            position: relative;
            z-index: 2;
        }
        
        /* Stats Cards with organic design */
        .stats {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 24px;
            margin-bottom: 40px;
        }
        
        .stat-card {
            background: var(--muted);
            padding: 32px;
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow-soft);
            border: 1px solid var(--border);
            position: relative;
            overflow: hidden;
            transition: all 0.3s ease;
        }
        
        /* Asymmetric organic radii for stat cards */
        .stat-card:nth-child(1) {
            border-radius: var(--radius-lg) var(--radius-md) var(--radius-xl) var(--radius-sm);
        }
        
        .stat-card:nth-child(2) {
            border-radius: var(--radius-md) var(--radius-xl) var(--radius-sm) var(--radius-lg);
        }
        
        .stat-card:nth-child(3) {
            border-radius: var(--radius-xl) var(--radius-sm) var(--radius-md) var(--radius-lg);
        }
        
        .stat-card:hover {
            transform: translateY(-4px);
            box-shadow: var(--shadow-hover);
        }
        
        .stat-card h3 {
            color: var(--muted-foreground);
            font-size: 0.9rem;
            font-weight: 600;
            margin-bottom: 12px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        .stat-card .value {
            font-family: var(--font-heading);
            font-size: 2.5rem;
            font-weight: 700;
            color: var(--primary);
            line-height: 1;
        }
        
        /* Tenants Section - Organic card-based layout */
        .tenants-section {
            background: var(--muted);
            border-radius: var(--radius-xl);
            padding: 32px;
            box-shadow: var(--shadow-soft);
            border: 1px solid var(--border);
            margin-bottom: 40px;
            position: relative;
            overflow: hidden;
        }
        
        .tenants-section::before {
            content: '';
            position: absolute;
            top: -10%;
            right: -5%;
            width: 25%;
            height: 30%;
            background: var(--primary);
            border-radius: 50% 40% 60% 30%;
            filter: blur(2rem);
            opacity: 0.05;
        }
        
        .tenants-section h2 {
            font-family: var(--font-heading);
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--foreground);
            margin-bottom: 24px;
            position: relative;
            z-index: 2;
        }
        
        /* Transform table to organic card grid */
        .tenants-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 20px;
        }
        
        .tenant-card {
            background: var(--background);
            padding: 24px;
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow-soft);
            border: 1px solid var(--border);
            position: relative;
            overflow: hidden;
            transition: all 0.3s ease;
        }
        
        /* Organic card variations */
        .tenant-card:nth-child(odd) {
            border-radius: var(--radius-md) var(--radius-lg) var(--radius-sm) var(--radius-xl);
        }
        
        .tenant-card:nth-child(even) {
            border-radius: var(--radius-xl) var(--radius-sm) var(--radius-lg) var(--radius-md);
        }
        
        .tenant-card:hover {
            transform: translateY(-2px) rotate(0.5deg);
            box-shadow: var(--shadow-hover);
        }
        
        .tenant-name {
            font-family: var(--font-heading);
            font-size: 1.2rem;
            font-weight: 600;
            color: var(--foreground);
            margin-bottom: 8px;
        }
        
        .tenant-details {
            display: flex;
            flex-direction: column;
            gap: 6px;
            margin-bottom: 16px;
        }
        
        .tenant-detail {
            font-size: 0.9rem;
            color: var(--muted-foreground);
        }
        
        .tenant-balance {
            font-family: var(--font-heading);
            font-size: 1.4rem;
            font-weight: 700;
            margin-bottom: 12px;
        }
        
        .tenant-balance.complete {
            color: var(--primary);
        }
        
        .tenant-balance.incomplete {
            color: var(--secondary);
        }
        
        .progress-container {
            display: flex;
            align-items: center;
            gap: 12px;
        }
        
        .progress-bar {
            flex: 1;
            height: 8px;
            background: var(--border);
            border-radius: 4px;
            overflow: hidden;
        }
        
        .progress-fill {
            height: 100%;
            background: var(--primary);
            border-radius: 4px;
            transition: width 0.5s ease;
        }
        
        .progress-text {
            font-size: 0.8rem;
            color: var(--muted-foreground);
            font-weight: 600;
        }
        
        .status-badge {
            display: inline-block;
            padding: 6px 16px;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 600;
            margin-top: 12px;
        }
        
        .status-complete {
            background: var(--primary);
            color: var(--primary-foreground);
        }
        
        .status-incomplete {
            background: var(--accent);
            color: var(--accent-foreground);
        }
        
        /* Repairs Section with organic design */
        .repairs-section {
            background: var(--muted);
            border-radius: var(--radius-xl);
            padding: 32px;
            box-shadow: var(--shadow-soft);
            border: 1px solid var(--border);
            position: relative;
            overflow: hidden;
        }
        
        .repairs-section::before {
            content: '';
            position: absolute;
            bottom: -15%;
            left: -8%;
            width: 30%;
            height: 40%;
            background: var(--secondary);
            border-radius: 40% 60% 30% 70%;
            filter: blur(2.5rem);
            opacity: 0.08;
        }
        
        .repairs-section h2 {
            font-family: var(--font-heading);
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--foreground);
            margin-bottom: 24px;
            position: relative;
            z-index: 2;
        }
        
        .repair-item {
            background: var(--background);
            padding: 20px;
            border-radius: var(--radius-lg);
            border: 1px solid var(--border);
            margin-bottom: 16px;
            position: relative;
            transition: all 0.3s ease;
        }
        
        /* Organic repair card variations */
        .repair-item:nth-child(2) {
            border-radius: var(--radius-md) var(--radius-xl) var(--radius-lg) var(--radius-sm);
            transform: rotate(-0.5deg);
        }
        
        .repair-item:nth-child(3) {
            border-radius: var(--radius-xl) var(--radius-sm) var(--radius-md) var(--radius-lg);
            transform: rotate(0.3deg);
        }
        
        .repair-item:hover {
            transform: translateY(-2px) rotate(0deg);
            box-shadow: var(--shadow-hover);
        }
        
        .repair-house {
            font-family: var(--font-heading);
            font-weight: 600;
            color: var(--foreground);
            margin-bottom: 6px;
        }
        
        .repair-description {
            color: var(--muted-foreground);
            margin-bottom: 8px;
            font-size: 0.95rem;
        }
        
        .repair-date {
            font-size: 0.8rem;
            color: var(--muted-foreground);
            opacity: 0.7;
        }
        
        .repair-status {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 600;
            margin-top: 12px;
            background: var(--accent);
            color: var(--accent-foreground);
        }
        
        .repairs-note {
            margin-top: 20px;
            padding: 16px;
            background: var(--background);
            border-radius: var(--radius-md);
            border: 1px solid var(--border);
            font-size: 0.9rem;
            color: var(--muted-foreground);
            font-style: italic;
        }
        
        /* Footer */
        .footer {
            text-align: center;
            margin-top: 48px;
            padding: 24px;
            color: var(--muted-foreground);
            font-size: 0.9rem;
            background: var(--muted);
            border-radius: var(--radius-lg);
            border: 1px solid var(--border);
            position: relative;
            overflow: hidden;
        }
        
        .footer::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 60%;
            height: 60%;
            background: var(--primary);
            border-radius: 50%;
            filter: blur(3rem);
            opacity: 0.03;
        }
        
        .footer span {
            position: relative;
            z-index: 2;
        }
        
        /* Responsive Design */
        @media (max-width: 768px) {
            body {
                padding: 16px;
            }
            
            .header {
                padding: 24px;
            }
            
            .header h1 {
                font-size: 1.5rem;
            }
            
            .stats {
                grid-template-columns: 1fr;
                gap: 16px;
            }
            
            .tenants-grid {
                grid-template-columns: 1fr;
            }
            
            .stat-card, .tenant-card, .repairs-section, .tenants-section {
                padding: 20px;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Header -->
        <div class="header">
            <h1>BomaFlow Landlord Dashboard</h1>
            <p>Landlord: <%= landlordPhone %></p>
            <p><%= currentDate %></p>
        </div>
        
        <!-- Stats -->
        <div class="stats">
            <div class="stat-card">
                <h3>Total Tenants</h3>
                <div class="value"><%= tenants.length %></div>
            </div>
            <div class="stat-card">
                <h3>Total Collected This Month</h3>
                <div class="value">KES <%= totalCollected %></div>
            </div>
            <div class="stat-card">
                <h3>Rent Target per Tenant</h3>
                <div class="value">KES 6,000</div>
            </div>
        </div>
        
        <!-- Tenants Section -->
        <div class="tenants-section">
            <h2>Tenants</h2>
            <% if (tenants.length === 0) { %>
                <p>No tenants found for this landlord.</p>
            <% } else { %>
                <div class="tenants-grid">
                    <% tenants.forEach(tenant => { %>
                        <% const progress = (tenant.balance / (tenant.monthly_rent || 6000)) * 100; %>
                        <div class="tenant-card">
                            <div class="tenant-name"><%= tenant.name %></div>
                            <div class="tenant-details">
                                <div class="tenant-detail">House: <%= tenant.house %></div>
                                <div class="tenant-detail">Building: <%= tenant.building %></div>
                                <div class="tenant-detail">Phone: <%= tenant.phone %></div>
                            </div>
                            <div class="tenant-balance <%= tenant.balance >= (tenant.monthly_rent || 6000) ? 'complete' : 'incomplete' %>">
                                KES <%= tenant.balance %>
                            </div>
                            <div class="progress-container">
                                <div class="progress-bar">
                                    <div class="progress-fill" style="width: <%= Math.min(progress, 100) %>%;"></div>
                                </div>
                                <div class="progress-text"><%= Math.round(progress) %>%</div>
                            </div>
                            <div class="status-badge <%= tenant.balance >= (tenant.monthly_rent || 6000) ? 'status-complete' : 'status-incomplete' %>">
                                <%= tenant.balance >= (tenant.monthly_rent || 6000) ? 'Complete' : 'In Progress' %>
                            </div>
                            <button class="btn-remove-tenant" onclick="removeTenant('<%= tenant.phone %>', '<%= tenant.name %>')">
                                Remove
                            </button>
                        </div>
                    <% }) %>
                </div>
            <% } %>
        </div>
        
        <!-- Tenant Management -->
        <div class="tenant-management-section">
            <h2>Manage Tenants</h2>
            
            <!-- Add Tenant Form -->
            <div class="add-tenant-form">
                <h3>Add New Tenant</h3>
                <form id="addTenantForm">
                    <div class="form-row">
                        <input type="text" id="tenantName" placeholder="Tenant Name" required>
                        <input type="tel" id="tenantPhone" placeholder="Phone (254XXXXXXXXX)" pattern="254[0-9]{9}" required>
                    </div>
                    <div class="form-row">
                        <input type="text" id="tenantBuilding" placeholder="Building Name" required>
                        <input type="text" id="tenantHouse" placeholder="House Number" required>
                    </div>
                    <div class="form-row">
                        <input type="number" id="tenantRent" placeholder="Monthly Rent (KES)" value="6000" min="1000">
                        <input type="hidden" id="landlordPhone" value="<%= landlordPhone %>">
                    </div>
                    <button type="submit" class="btn-add-tenant">Add Tenant</button>
                </form>
            </div>
            
            <div id="tenantMessage" class="tenant-message"></div>
        </div>
        
        <!-- Repair Requests -->
        <div class="repairs-section">
            <h2>Recent Repair Requests</h2>
            <% if (repairs && repairs.length > 0) { %>
                <% repairs.forEach(repair => { %>
                    <div class="repair-item">
                        <div class="repair-house">House <%= repair.house %> - <%= repair.name %></div>
                        <div class="repair-description"><%= repair.issue_type %>: <%= repair.description %></div>
                        <div class="repair-date">Reported: <%= new Date(repair.date).toLocaleDateString() %></div>
                        <div class="repair-status"><%= repair.status || 'Pending' %></div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="repairs-note">
                    No repair requests received yet. Tenants can report issues via USSD.
                </div>
            <% } %>
        </div>
        
        <div class="footer">
            <span>BomaFlow - Daily Rent Micro-Savings</span>
        </div>
    </div>
    
    <script>
        // Add Tenant functionality
        document.getElementById('addTenantForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            
            const formData = {
                phone: document.getElementById('tenantPhone').value,
                name: document.getElementById('tenantName').value,
                building: document.getElementById('tenantBuilding').value,
                house: document.getElementById('tenantHouse').value,
                monthlyRent: parseInt(document.getElementById('tenantRent').value),
                landlordPhone: document.getElementById('landlordPhone').value
            };
            
            try {
                const response = await fetch('/api/tenants', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(formData)
                });
                
                const result = await response.json();
                
                if (result.success) {
                    showMessage('Tenant added successfully! Refreshing...', 'success');
                    setTimeout(() => {
                        window.location.reload();
                    }, 2000);
                } else {
                    showMessage(result.message || 'Failed to add tenant', 'error');
                }
            } catch (error) {
                showMessage('Error adding tenant. Please try again.', 'error');
            }
        });
        
        // Remove Tenant functionality
        async function removeTenant(phone, name) {
            if (confirm(`Are you sure you want to remove ${name}? This will delete all their payment and repair history.`)) {
                try {
                    const response = await fetch(`/api/tenants/${phone}`, {
                        method: 'DELETE'
                    });
                    
                    const result = await response.json();
                    
                    if (result.success) {
                        showMessage('Tenant removed successfully! Refreshing...', 'success');
                        setTimeout(() => {
                            window.location.reload();
                        }, 2000);
                    } else {
                        showMessage(result.message || 'Failed to remove tenant', 'error');
                    }
                } catch (error) {
                    showMessage('Error removing tenant. Please try again.', 'error');
                }
            }
        }
        
        // Show message function
        function showMessage(message, type) {
            const messageDiv = document.getElementById('tenantMessage');
            messageDiv.textContent = message;
            messageDiv.className = `tenant-message ${type}`;
            messageDiv.style.display = 'block';
            
            setTimeout(() => {
                messageDiv.style.display = 'none';
            }, 5000);
        }
    </script>
    
    <style>
        /* Tenant Management Styles */
        .tenant-management-section {
            background: var(--muted);
            border-radius: var(--radius-xl);
            padding: 32px;
            margin-bottom: 32px;
            box-shadow: var(--shadow-soft);
            border: 1px solid var(--border);
            position: relative;
            overflow: hidden;
        }
        
        .tenant-management-section::before {
            content: '';
            position: absolute;
            top: -10%;
            right: -5%;
            width: 25%;
            height: 35%;
            background: var(--primary);
            border-radius: 60% 40% 30% 70%;
            filter: blur(2.5rem);
            opacity: 0.08;
        }
        
        .add-tenant-form {
            background: var(--background);
            padding: 24px;
            border-radius: var(--radius-lg);
            border: 1px solid var(--border);
            margin-bottom: 20px;
        }
        
        .add-tenant-form h3 {
            font-family: var(--font-heading);
            font-size: 1.2rem;
            font-weight: 600;
            color: var(--foreground);
            margin-bottom: 20px;
        }
        
        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
            margin-bottom: 16px;
        }
        
        .form-row input {
            padding: 12px 16px;
            border: 2px solid var(--border);
            border-radius: var(--radius-md);
            font-family: var(--font-body);
            font-size: 0.95rem;
            background: var(--background);
            color: var(--foreground);
            transition: all 0.3s ease;
        }
        
        .form-row input:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(93, 112, 82, 0.1);
        }
        
        .btn-add-tenant {
            background: var(--primary);
            color: var(--primary-foreground);
            border: none;
            padding: 12px 24px;
            border-radius: var(--radius-lg);
            font-family: var(--font-heading);
            font-weight: 600;
            font-size: 0.95rem;
            cursor: pointer;
            transition: all 0.3s ease;
            width: 100%;
        }
        
        .btn-add-tenant:hover {
            background: var(--primary-hover);
            transform: translateY(-2px);
            box-shadow: var(--shadow-hover);
        }
        
        .btn-remove-tenant {
            background: var(--accent);
            color: var(--accent-foreground);
            border: none;
            padding: 8px 16px;
            border-radius: var(--radius-md);
            font-family: var(--font-body);
            font-weight: 600;
            font-size: 0.85rem;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-top: 12px;
        }
        
        .btn-remove-tenant:hover {
            background: #d4a574;
            transform: translateY(-1px);
        }
        
        .tenant-message {
            padding: 16px;
            border-radius: var(--radius-md);
            margin-top: 16px;
            font-family: var(--font-body);
            font-weight: 500;
            display: none;
        }
        
        .tenant-message.success {
            background: rgba(34, 197, 94, 0.1);
            color: #16a34a;
            border: 1px solid rgba(34, 197, 94, 0.2);
        }
        
        .tenant-message.error {
            background: rgba(239, 68, 68, 0.1);
            color: #dc2626;
            border: 1px solid rgba(239, 68, 68, 0.2);
        }
        
        @media (max-width: 768px) {
            .form-row {
                grid-template-columns: 1fr;
            }
        }
    </style>
</body>
</html>
